# Blog CMS API configuration
CMS_API_PORT=8787
CMS_DB_CLIENT=sqlite

# SQLite (used when CMS_DB_CLIENT=sqlite)
CMS_DB_PATH=server/db/cms.sqlite

# MySQL (used when CMS_DB_CLIENT=mysql)
CMS_MYSQL_HOST=127.0.0.1
CMS_MYSQL_PORT=3306
CMS_MYSQL_USER=root
CMS_MYSQL_PASSWORD=
CMS_MYSQL_DATABASE=honeytranslations_cms

CMS_JWT_SECRET=please-change-this-secret
CMS_JWT_EXPIRES_IN=12h
CMS_UPLOAD_DIR=public/uploads

# Default admin user (used by db:seed)
CMS_ADMIN_USERNAME=admin
CMS_ADMIN_EMAIL=admin@honeytranslations.com
CMS_ADMIN_PASSWORD=Admin@12345

# Frontend API base (optional). Leave empty for same-origin /api.
VITE_CMS_API_BASE=
